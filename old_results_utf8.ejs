          <div class="col-md-4 form-group-admin mb-0">
            <label class="admin-label">αª╕αºçαª╢αª¿ αª¿αª┐αª░αºìαª¼αª╛αªÜαª¿ αªòαª░αºüαª¿</label>
            <select id="filterSession" class="admin-select">
              <option value="">ΓÇö αª»αºçαªòαºïαª¿αºï αª╕αºçαª╢αª¿ ΓÇö</option>
              <% if(typeof sessions !== 'undefined' && sessions.length > 0) { %>
                <% sessions.forEach(s => { %>
