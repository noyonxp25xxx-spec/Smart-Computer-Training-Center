<footer class="footer-main">
  <div class="container">
    <div class="row g-4">
      <!-- Brand -->
      <div class="col-lg-4 col-md-6">
        <img src="<%= site.logoUrl || '/images/default-logo.png' %>" alt="Logo" class="footer-logo" />
        <div class="footer-brand-name">
          <%= site.name %>
        </div>
        <div class="footer-tagline">
          <%= site.tagline %>
        </div>
        <p class="footer-about">আধুনিক প্রযুক্তি শিক্ষায় দক্ষ মানবসম্পদ তৈরিতে আমরা প্রতিশ্রুতিবদ্ধ। আমাদের কোর্সগুলো
          বাস্তবমুখী ও কর্মমুখী।</p>
        <div class="footer-social">
          <% if(site.fbUrl) { %><a href="<%= site.fbUrl %>" target="_blank" aria-label="Facebook"><i
                class="bi bi-facebook"></i></a>
            <% } %>
              <% if(site.ytUrl) { %><a href="<%= site.ytUrl %>" target="_blank" aria-label="YouTube"><i
                    class="bi bi-youtube"></i></a>
                <% } %>
                  <a href="#" aria-label="WhatsApp"><i class="bi bi-whatsapp"></i></a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="col-lg-2 col-md-6 col-6">
        <h6 class="footer-heading">দ্রুত লিঙ্ক</h6>
        <ul class="footer-links">
          <li><a href="/"><i class="bi bi-chevron-right"></i> হোম</a></li>
          <li><a href="/about"><i class="bi bi-chevron-right"></i> পরিচিতি</a></li>
          <li><a href="/courses"><i class="bi bi-chevron-right"></i> কোর্সসমূহ</a></li>
          <li><a href="/notices"><i class="bi bi-chevron-right"></i> নোটিশ</a></li>
          <li><a href="/blog"><i class="bi bi-chevron-right"></i> আইটি তথ্য</a></li>
          <li><a href="/gallery"><i class="bi bi-chevron-right"></i> গ্যালারি</a></li>
        </ul>
      </div>

      <!-- Student Services -->
      <div class="col-lg-2 col-md-6 col-6">
        <h6 class="footer-heading">শিক্ষার্থী সেবা</h6>
        <ul class="footer-links">
          <li><a href="/result"><i class="bi bi-chevron-right"></i> ফলাফল দেখুন</a></li>
          <li><a href="/admission"><i class="bi bi-chevron-right"></i> অনলাইন ভর্তি</a></li>
          <li><a href="/students"><i class="bi bi-chevron-right"></i> শিক্ষার্থীবৃন্দ</a></li>
          <li><a href="/teachers"><i class="bi bi-chevron-right"></i> শিক্ষকমণ্ডলী</a></li>
          <li><a href="/committee"><i class="bi bi-chevron-right"></i> পরিচালনা কমিটি</a></li>
          <li><a href="/contact"><i class="bi bi-chevron-right"></i> যোগাযোগ</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="col-lg-4 col-md-6">
        <h6 class="footer-heading">যোগাযোগ</h6>
        <div class="footer-contact-item">
          <i class="bi bi-geo-alt-fill"></i>
          <span>
            <%= site.address || 'ঠিকানা দেওয়া হয়নি' %>
          </span>
        </div>
        <div class="footer-contact-item">
          <i class="bi bi-telephone-fill"></i>
          <span>
            <%= site.phone || '—' %>
          </span>
        </div>
        <div class="footer-contact-item">
          <i class="bi bi-envelope-fill"></i>
          <span>
            <%= site.email || '—' %>
          </span>
        </div>
        <% if(site.mapEmbed) { %>
          <div class="mt-3 rounded overflow-hidden" style="height:150px;">
            <%- site.mapEmbed %>
          </div>
          <% } %>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>
        <%= site.footerText || `© ${new Date().getFullYear()} ${site.name}. সর্বস্বত্ব সংরক্ষিত।` %>
      </p>
      <p style="margin-top:8px; font-size:.85rem; color:rgba(255,255,255,.6);">
        Developed by <a href="https://wa.me/8801706338181" target="_blank"
          style="color:var(--blue); font-weight:700; text-decoration:none;">Imran</a>
      </p>
    </div>
  </div>
</footer>