<%
/**
 * Admin Page Wrapper Macro
 * Usage: Each admin page includes this at top and bottom.
 * Provides: DOCTYPE, head, sidebar, topbar, content wrapper.
 * include('../partials/admin-head', {title})
 * ... page content ...
 * include('../partials/admin-foot')
 */
%>
<!DOCTYPE html><html lang="bn"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title><%= title %> — Admin | <%= site.name %></title>
<link rel="icon" href="<%= site.faviconUrl||'/images/favicon.png' %>"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="/css/admin.css"/>
</head><body>
<%- include('./preloader') %>
<div id="toastContainer" class="toast-container"></div>
<%- include('./admin-sidebar') %>
<div class="admin-main">
  <header class="admin-topbar">
    <div class="d-flex align-items-center gap-3">
      <button id="sidebarToggle" style="background:none;border:none;font-size:1.3rem;color:var(--admin-navy);cursor:pointer"><i class="bi bi-list"></i></button>
      <span class="topbar-title"><%= title %></span>
    </div>
    <div class="topbar-actions"><span class="topbar-time" id="adminClock"></span></div>
  </header>
  <div class="admin-content">
