<!DOCTYPE html>
<html lang="bn">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | <%= site.name %></title>
  <meta name="description" content="<%= site.tagline || site.name %> — আধুনিক কম্পিউটার প্রশিক্ষণ কেন্দ্র" />
  <link rel="icon" href="/logo.png" />
  <!-- Bootstrap 5 -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <!-- Custom -->
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .reveal { opacity: 0; transform: translateY(24px); transition: opacity .6s ease, transform .6s ease; }
    .reveal.revealed { opacity: 1; transform: none; }
  </style>
</head>
<body>

<!-- Notice Ticker -->
<% if (tickerNotices && tickerNotices.length > 0) { %>
<div class="notice-ticker">
  <div class="d-flex align-items-center">
    <span class="ticker-label"><i class="bi bi-bell-fill me-1"></i> নোটিশ</span>
    <div class="ticker-wrap">
      <div class="ticker-track">
        <% tickerNotices.forEach(n => { %><span><%= n.title %></span><% }); %>
        <% tickerNotices.forEach(n => { %><span><%= n.title %></span><% }); %>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Navbar -->
<%- include('../partials/navbar') %>

<!-- Main Content -->
<main>
  <%- body %>
</main>

<!-- Footer -->
<%- include('../partials/footer') %>

<!-- Lightbox -->
<div class="lightbox" id="lightbox">
  <button class="lightbox-close" id="lightboxClose">&times;</button>
  <img src="" id="lightboxImg" alt="Gallery Image" />
</div>

<!-- Alert Placeholder -->
<div class="alert-placeholder" style="position:fixed;top:20px;left:50%;transform:translateX(-50%);z-index:9999;width:90%;max-width:500px;"></div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<!-- Main JS -->
<script src="/js/main.js"></script>
</body>
</html>
