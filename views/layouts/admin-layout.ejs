<!DOCTYPE html><html lang="bn"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title><%= title %> — Admin | <%= site.name %></title>
<link rel="icon" href="/logo.png"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="/css/admin.css"/>
</head><body>
<div id="toastContainer" class="toast-container"></div>

<!-- SIDEBAR -->
<aside class="admin-sidebar" id="adminSidebar">
  <a href="/admin" class="sidebar-brand">
    <img src="<%= site.logoUrl||'/images/default-logo.png' %>" alt="Logo" onerror="this.style.display='none'"/>
    <div class="sidebar-brand-text"><div class="name"><%= site.name %></div><div class="sub">Admin Panel</div></div>
  </a>

  <nav class="sidebar-nav">
    <div class="nav-section-label">প্রধান</div>
    <a href="/admin" class="sidebar-link <%= currentPath==='/admin'?'active':'' %>"><i class="bi bi-speedometer2"></i> ড্যাশবোর্ড</a>
    <a href="/admin/settings" class="sidebar-link <%= currentPath==='/admin/settings'?'active':'' %>"><i class="bi bi-gear-fill"></i> সাইট সেটিংস</a>

    <div class="nav-section-label">কনটেন্ট</div>
    <a href="/admin/sliders" class="sidebar-link <%= currentPath==='/admin/sliders'?'active':'' %>"><i class="bi bi-images"></i> ব্যানার/স্লাইডার</a>
    <a href="/admin/courses" class="sidebar-link <%= currentPath==='/admin/courses'?'active':'' %>"><i class="bi bi-book-fill"></i> কোর্স</a>
    <a href="/admin/notices" class="sidebar-link <%= currentPath==='/admin/notices'?'active':'' %>"><i class="bi bi-bell-fill"></i> নোটিশ</a>
    <a href="/admin/blog" class="sidebar-link <%= currentPath==='/admin/blog'?'active':'' %>"><i class="bi bi-journal-text"></i> ব্লগ/আইটি তথ্য</a>
    <a href="/admin/gallery" class="sidebar-link <%= currentPath==='/admin/gallery'?'active':'' %>"><i class="bi bi-camera-fill"></i> গ্যালারি</a>

    <div class="nav-section-label">মানবসম্পদ</div>
    <a href="/admin/teachers" class="sidebar-link <%= currentPath==='/admin/teachers'?'active':'' %>"><i class="bi bi-person-badge-fill"></i> শিক্ষক</a>
    <a href="/admin/committee" class="sidebar-link <%= currentPath==='/admin/committee'?'active':'' %>"><i class="bi bi-people-fill"></i> কমিটি</a>
    <a href="/admin/students" class="sidebar-link <%= currentPath==='/admin/students'?'active':'' %>"><i class="bi bi-mortarboard-fill"></i> শিক্ষার্থী</a>

    <div class="nav-section-label">পরীক্ষা ও ভর্তি</div>
    <a href="/admin/results" class="sidebar-link <%= currentPath==='/admin/results'?'active':'' %>"><i class="bi bi-clipboard2-check-fill"></i> রেজাল্ট ম্যানেজার</a>
    <a href="/admin/admissions" class="sidebar-link <%= currentPath==='/admin/admissions'?'active':'' %>"><i class="bi bi-pen-fill"></i> ভর্তি আবেদন</a>

    <div class="nav-section-label">যোগাযোগ ও সিস্টেম</div>
    <a href="/admin/messages" class="sidebar-link <%= currentPath==='/admin/messages'?'active':'' %>"><i class="bi bi-chat-dots-fill"></i> বার্তা</a>
    <a href="/admin/users" class="sidebar-link <%= currentPath==='/admin/users'?'active':'' %>"><i class="bi bi-shield-fill"></i> অ্যাডমিন ব্যবস্থাপনা</a>
    <a href="/admin/activity-log" class="sidebar-link <%= currentPath==='/admin/activity-log'?'active':'' %>"><i class="bi bi-clock-history"></i> কার্যক্রম লগ</a>
    <a href="/" target="_blank" class="sidebar-link"><i class="bi bi-box-arrow-up-right"></i> সাইট দেখুন</a>
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-admin-info">
      <div class="admin-avatar"><%= (admin.email||'A').charAt(0).toUpperCase() %></div>
      <div><div class="admin-email"><%= admin.email %></div><div class="admin-role"><%= admin.role||'admin' %></div></div>
    </div>
    <form action="/admin/logout" method="POST"><button type="submit" class="btn-logout"><i class="bi bi-box-arrow-left"></i> লগআউট</button></form>
  </div>
</aside>

<!-- MAIN -->
<div class="admin-main">
  <header class="admin-topbar">
    <div class="d-flex align-items-center gap-3">
      <button id="sidebarToggle" style="background:none;border:none;font-size:1.3rem;color:var(--admin-navy);cursor:pointer;display:none"><i class="bi bi-list"></i></button>
      <span class="topbar-title"><%= title %></span>
    </div>
    <div class="topbar-actions">
      <span class="topbar-time" id="adminClock"></span>
    </div>
  </header>
  <div class="admin-content">
    <%- body %>
  </div>
</div>

<script src="/js/admin.js"></script>
</body></html>
