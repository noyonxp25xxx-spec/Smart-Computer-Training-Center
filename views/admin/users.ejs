<%- include('../partials/admin-head') %>

<div class="row g-4">
  <!-- Add Admin User (Only visible to Main Admin) -->
  <% if (admin.uid === 'system-admin') { %>
  <div class="col-lg-4">
    <div class="table-card">
      <div class="table-card-header"><span class="table-card-title">নতুন অ্যাডমিন/স্টাফ যোগ করুন</span></div>
      <div style="padding: 24px">
        <form id="addAdminForm">
          <div class="form-group-admin" style="margin-top:14px">
            <label class="admin-label">ইমেইল *</label>
            <input type="email" name="email" class="admin-input" required autocomplete="new-email"/>
          </div>
          <div class="form-group-admin" style="margin-top:14px">
            <label class="admin-label">পাসওয়ার্ড *</label>
            <input type="text" name="password" class="admin-input" required autocomplete="new-password"/>
          </div>
          <div class="form-group-admin" style="margin-top:14px">
            <label class="admin-label">অ্যাকাউন্ট রোল</label>
            <select name="role" class="admin-select">
              <option value="admin">সাধারণ অ্যাডমিন (Admin)</option>
              <option value="superadmin">সুপার অ্যাডমিন (Super Admin)</option>
              <option value="result-manager">ফলাফল ব্যবস্থাপক (Result Manager)</option>
            </select>
          </div>

          <button type="submit" class="btn-save" style="width:100%;margin-top:14px"><i class="bi bi-person-plus me-2"></i>অ্যাকাউন্ট তৈরি করুন</button>
        </form>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Admins List -->
  <div class="<%= admin.uid === 'system-admin' ? 'col-lg-8' : 'col-12' %>">
    <div class="table-card">
      <div class="table-card-header"><span class="table-card-title">অ্যাডমিন অ্যাকাউন্ট সমূহ</span></div>
      <table class="data-table" id="adminsTable">
        <thead>
          <tr>
            <th>লগইন ইমেইল</th>
            <th>লগইন পাসওয়ার্ড</th>
            <th>রোল</th>
            <th>অ্যাকশন</th>
          </tr>
        </thead>
        <tbody>
          <% if(admins && admins.length > 0) { admins.forEach(u => { %>
          <tr id="row-<%= u.id %>">
            <td style="font-weight:600;"><%= u.email || '—' %></td>
            <td style="font-weight:600;"><%= u.password || '—' %></td>
            <td>
              <span class="badge badge-<%= u.role === 'superadmin' ? 'success' : u.role === 'result-manager' ? 'blue' : 'gray' %>">
                <%= u.role === 'superadmin' ? 'Super Admin' : u.role === 'result-manager' ? 'Result Manager' : 'Admin' %>
              </span>
            </td>
            <td>
              <% if(admin.uid === 'system-admin' && u.role !== 'superadmin') { %>
              <button class="action-btn delete" onclick="deleteAdminAccount('<%= u.id %>')"><i class="bi bi-trash"></i></button>
              <% } else if (u.role === 'superadmin') { %>
              <span style="font-size: .8rem; color: var(--admin-gray-500);">সিস্টেম সুরক্ষিত</span>
              <% } else { %>
              <span style="font-size: .8rem; color: var(--admin-gray-500);">অনুমতি নেই</span>
              <% } %>
            </td>
          </tr>
          <% }); } else { %>
          <tr><td colspan="5" style="text-align:center;padding:24px;color:var(--admin-gray-500)">কোনো অ্যাকাউন্ট পাওয়া যায়নি</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
document.getElementById('addAdminForm').addEventListener('submit', async e => {
  e.preventDefault();
  const formData = new FormData(e.target);
  
  // Collect multiple checkboxes manually if needed, or serialize form
  const payload = {
    email: formData.get('email'),
    password: formData.get('password'),
    role: formData.get('role')
  };

  const res = await fetch('/admin/users', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  });
  const data = await res.json();
  showToast(data.success ? 'অ্যাডমিন অ্যাকাউন্ট সফলভাবে তৈরি হয়েছে' : 'ত্রুটি: ' + data.message, data.success ? 'success' : 'error');
  if(data.success) setTimeout(() => location.reload(), 1200);
});

function deleteAdminAccount(uid) {
  confirmDelete(`/admin/users/${uid}`, () => {
    document.getElementById(`row-${uid}`)?.remove();
  });
}
</script>

<%- include('../partials/admin-foot') %>
