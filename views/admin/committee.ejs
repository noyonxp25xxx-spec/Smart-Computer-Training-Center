<%- include('../partials/admin-head') %>

<div style="margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center;">
  <div class="search-bar" style="max-width: 300px;">
    <i class="bi bi-search"></i>
    <input type="text" data-search-table="committeeTable" placeholder="কমিটির সদস্য খুঁজুন...">
  </div>
  <button class="topbar-btn" onclick="openModal('addCommitteeModal')"><i class="bi bi-plus-lg me-2"></i>নতুন সদস্য যোগ করুন</button>
</div>

<div class="table-card">
  <table class="data-table" id="committeeTable">
    <thead>
      <tr>
        <th>ছবি</th>
        <th>নাম</th>
        <th>পদবি</th>
        <th>ক্রম</th>
        <th>অ্যাকশন</th>
      </tr>
    </thead>
    <tbody>
      <% if(members && members.length > 0) { members.forEach(m => { %>
      <tr id="row-<%= m.id %>">
        <td><img src="<%= m.imageUrl || '/images/teacher-default.jpg' %>" class="thumb" alt="member"></td>
        <td style="font-weight:600;"><%= m.name %></td>
        <td><%= m.designation || '—' %></td>
        <td><%= m.order %></td>
        <td>
          <button class="action-btn edit" onclick="editCommittee(<%= JSON.stringify(m) %>)"><i class="bi bi-pencil"></i></button>
          <button class="action-btn delete" onclick="deleteCommittee('<%= m.id %>')"><i class="bi bi-trash"></i></button>
        </td>
      </tr>
      <% }); } else { %>
      <tr><td colspan="5" style="text-align:center;padding:24px;color:var(--admin-gray-500)">কোনো সদস্য পাওয়া যায়নি</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<!-- Add Committee Modal -->
<div class="modal-overlay" id="addCommitteeModal">
  <div class="modal-box">
    <div class="modal-header">
      <span class="modal-title">নতুন সদস্য যোগ করুন</span>
      <button class="modal-close" data-modal-close="addCommitteeModal">&times;</button>
    </div>
    <form id="addCommitteeForm" enctype="multipart/form-data">
      <div class="modal-body">
        <div class="form-group-admin">
          <label class="admin-label">সদস্যের নাম *</label>
          <input type="text" name="name" class="admin-input" required/>
        </div>
        <div class="form-group-admin">
          <label class="admin-label">পদবি *</label>
          <input type="text" name="designation" class="admin-input" required/>
        </div>
        <div class="form-group-admin">
          <label class="admin-label">ক্রম (Order)</label>
          <input type="number" name="order" class="admin-input" value="1"/>
        </div>
        <div class="form-group-admin">
          <label class="admin-label">ছবি</label>
          <input type="file" name="image" class="admin-input" accept="image/*" data-preview="addMemberImgPreview"/>
          <img id="addMemberImgPreview" class="img-preview"/>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-cancel" data-modal-close="addCommitteeModal">বাতিল</button>
        <button type="submit" class="btn-save">সংরক্ষণ করুন</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Committee Modal -->
<div class="modal-overlay" id="editCommitteeModal">
  <div class="modal-box">
    <div class="modal-header">
      <span class="modal-title">সদস্য তথ্য সম্পাদন করুন</span>
      <button class="modal-close" data-modal-close="editCommitteeModal">&times;</button>
    </div>
    <form id="editCommitteeForm" enctype="multipart/form-data">
      <input type="hidden" id="editCommitteeId"/>
      <div class="modal-body">
        <div class="form-group-admin">
          <label class="admin-label">সদস্যের নাম *</label>
          <input type="text" name="name" id="editCommitteeName" class="admin-input" required/>
        </div>
        <div class="form-group-admin">
          <label class="admin-label">পদবি *</label>
          <input type="text" name="designation" id="editCommitteeDesignation" class="admin-input" required/>
        </div>
        <div class="form-group-admin">
          <label class="admin-label">ক্রম (Order)</label>
          <input type="number" name="order" id="editCommitteeOrder" class="admin-input"/>
        </div>
        <div class="form-group-admin">
          <label class="admin-label">ছবি (পরিবর্তন করতে চাইলে)</label>
          <input type="file" name="image" class="admin-input" accept="image/*" data-preview="editMemberImgPreview"/>
          <img id="editMemberImgPreview" class="img-preview"/>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-cancel" data-modal-close="editCommitteeModal">বাতিল</button>
        <button type="submit" class="btn-save">আপডেট করুন</button>
      </div>
    </form>
  </div>
</div>

<script>
document.getElementById('addCommitteeForm').addEventListener('submit', async e => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const res = await fetch('/admin/committee', { method: 'POST', body: fd });
  const data = await res.json();
  showToast(data.message || 'সদস্য যোগ সফল হয়েছে', data.success ? 'success' : 'error');
  if(data.success) setTimeout(() => location.reload(), 1200);
});

function editCommittee(m) {
  document.getElementById('editCommitteeId').value = m.id;
  document.getElementById('editCommitteeName').value = m.name || '';
  document.getElementById('editCommitteeDesignation').value = m.designation || '';
  document.getElementById('editCommitteeOrder').value = m.order || 1;
  
  const preview = document.getElementById('editMemberImgPreview');
  if(m.imageUrl) {
    preview.src = m.imageUrl;
    preview.classList.add('show');
  } else {
    preview.classList.remove('show');
  }
  openModal('editCommitteeModal');
}

document.getElementById('editCommitteeForm').addEventListener('submit', async e => {
  e.preventDefault();
  const id = document.getElementById('editCommitteeId').value;
  const fd = new FormData(e.target);
  const res = await fetch(`/admin/committee/${id}`, { method: 'PUT', body: fd });
  const data = await res.json();
  showToast(data.message || 'আপডেট সফল হয়েছে', data.success ? 'success' : 'error');
  if(data.success) setTimeout(() => location.reload(), 1200);
});

function deleteCommittee(id) {
  confirmDelete(`/admin/committee/${id}`, () => {
    document.getElementById(`row-${id}`)?.remove();
  });
}
</script>

<%- include('../partials/admin-foot') %>
