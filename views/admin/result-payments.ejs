<%- include('../partials/admin-head') %>

<div style="margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center;">
  <div class="search-bar" style="max-width: 300px;">
    <i class="bi bi-search"></i>
    <input type="text" data-search-table="resultPaymentsTable" placeholder="রেজিস্ট্রেশন নম্বর বা নাম খুঁজুন...">
  </div>
</div>

<div class="table-card">
  <table class="data-table" id="resultPaymentsTable">
    <thead>
      <tr>
        <th>রেজিস্ট্রেশন নম্বর</th>
        <th>নাম</th>
        <th>কোর্স</th>
        <th>সেশন</th>
        <th>ফলাফল স্ট্যাটাস</th>
        <th>পেমেন্ট স্ট্যাটাস</th>
        <th>অ্যাকশন</th>
      </tr>
    </thead>
    <tbody>
      <% if(students && students.length > 0) { students.forEach(s => { %>
      <tr id="row-<%= s.regNo %>">
        <td style="font-weight:700; color: var(--admin-blue);"><%= s.regNo %></td>
        <td style="font-weight:600;"><%= s.name %></td>
        <td><%= s.course || '—' %></td>
        <td><%= s.session || '—' %></td>
        <td>
          <% if(s.isPassed === true) { %>
            <span class="badge badge-success">উত্তীর্ণ</span>
          <% } else if(s.isPassed === false) { %>
            <span class="badge badge-danger">অকৃতকার্য</span>
          <% } else { %>
            <span class="badge badge-pending">অপ্রকাশিত</span>
          <% } %>
        </td>
        <td>
          <span class="badge badge-<%= s.resultPaymentStatus==='paid'?'success':'danger' %>" id="paybadge-<%= s.regNo %>">
            <%= s.resultPaymentStatus==='paid'?'পরিশোধিত':'অপরিশোধিত' %>
          </span>
        </td>
        <td>
            <% if (s.resultPaymentStatus !== 'paid') { %>
              <button class="action-btn edit" onclick="markResultAsPaid('<%= s.regNo %>', this)" title="পেমেন্ট সম্পন্ন করুন" style="background:rgba(245,158,11,.1);color:var(--admin-warning);"><i class="bi bi-currency-dollar"></i></button>
            <% } %>
        </td>
      </tr>
      <% }); } else { %>
      <tr><td colspan="7" style="text-align:center;padding:24px;color:var(--admin-gray-500)">কোনো ডাটা পাওয়া যায়নি</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<script>
async function markResultAsPaid(regNo, btnElement) {
  if (btnElement) btnElement.disabled = true;
  if (!confirm('আপনি কি নিশ্চিত যে রেজাল্টের পেমেন্ট সম্পন্ন হয়েছে?')) {
    if (btnElement) btnElement.disabled = false;
    return;
  }
  try {
    const res = await apiCall(`/admin/result-payments/${regNo}`, 'PUT', { resultPaymentStatus: 'paid' });
    if(res.success) {
      showToast('পেমেন্ট স্ট্যাটাস আপডেট হয়েছে', 'success');
      setTimeout(() => location.reload(), 1200);
    } else {
      showToast('আপডেট ব্যর্থ হয়েছে', 'error');
      if (btnElement) btnElement.disabled = false;
    }
  } catch {
    showToast('সংযোগ ত্রুটি', 'error');
    if (btnElement) btnElement.disabled = false;
  }
}
</script>

<%- include('../partials/admin-foot') %>
