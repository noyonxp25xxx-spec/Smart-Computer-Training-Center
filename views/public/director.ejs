<!DOCTYPE html><html lang="bn"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title><%= title %> | <%= site.name %></title><link rel="icon" href="<%= site.faviconUrl||'/images/favicon.png' %>"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="/css/style.css"/>
<style>.reveal{opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease}.reveal.revealed{opacity:1;transform:none}</style>
</head><body>
<% if(tickerNotices&&tickerNotices.length>0){%><div class="notice-ticker"><div class="d-flex align-items-center"><span class="ticker-label"><i class="bi bi-bell-fill me-1"></i>নোটিশ</span><div class="ticker-wrap"><div class="ticker-track"><%tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});%></div></div></div></div><%}%>
<%- include('../partials/navbar') %>
<main>
<section class="breadcrumb-section"><div class="container"><h1 class="breadcrumb-title"><%=title%></h1><ul class="breadcrumb-nav"><li><a href="/">হোম</a></li><li><%=title%></li></ul></div></section>

<section class="section">
  <div class="container">
    <% if(directors && directors.length > 0) { directors.forEach((director, idx) => { %>
    <div class="row g-5 align-items-start mb-5 <%= idx > 0 ? 'pt-5 border-top' : '' %>">
      <div class="col-lg-5 reveal">
        <% if(director && director.imageUrl){ %>
        <img src="<%= director.imageUrl %>" alt="<%= director.name||'পরিচালক' %>" class="img-fluid rounded-3 shadow w-100" style="max-height:420px;object-fit:contain;background:#f8fafc;padding:10px;"/>
        <% } else { %>
        <div style="background:linear-gradient(135deg,#0A1628,#1E90FF);border-radius:16px;height:380px;display:flex;align-items:center;justify-content:center;font-size:6rem;">👤</div>
        <% } %>
        <div class="mt-3 p-4 rounded-3" style="background:var(--gray-100)">
          <h4 style="color:var(--navy);font-weight:800"><%= director.name||'পরিচালকের নাম' %></h4>
          <p style="color:var(--blue);font-weight:600;margin:0"><%= director.designation||'পরিচালক' %></p>
          <p style="color:var(--gray-500);font-size:.85rem;margin-top:6px"><%= director.institution || site.name %></p>
          <% if(director.address) { %><p style="color:var(--gray-500);font-size:.85rem;margin-top:2px"><i class="bi bi-geo-alt"></i> <%= director.address %></p><% } %>
        </div>
      </div>
      <div class="col-lg-7 reveal">
        <div class="section-title"><%= director.name %> এর বাণী</div>
        <div class="section-line"></div>
        <div style="font-size:3rem;color:var(--blue);line-height:1;margin-bottom:14px">"</div>
        <div style="font-size:1rem;line-height:2;color:var(--gray-700)">
          <%- director.message ? director.message.replace(/\n/g,'<br>') : 'কোনো বাণী সংযুক্ত করা হয়নি।' %>
        </div>
        <div style="font-size:3rem;color:var(--blue);line-height:1;text-align:right;margin-top:10px">"</div>
      </div>
    </div>
    <% }) } else { %>
      <div class="text-center py-5">
        <h4 class="text-muted">কোনো পরিচালকের তথ্য পাওয়া যায়নি।</h4>
      </div>
    <% } %>
  </div>
</section>
</main>
<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body></html>
