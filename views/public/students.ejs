<!DOCTYPE html><html lang="bn"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title><%= title %> | <%= site.name %></title><link rel="icon" href="<%= site.faviconUrl||'/images/favicon.png' %>"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="/css/style.css"/>
<style>.reveal{opacity:0;transform:translateY(24px);transition:.6s ease}.reveal.revealed{opacity:1;transform:none}</style>
</head><body>
<% if(tickerNotices&&tickerNotices.length>0){%><div class="notice-ticker"><div class="d-flex align-items-center"><span class="ticker-label"><i class="bi bi-bell-fill me-1"></i>নোটিশ</span><div class="ticker-wrap"><div class="ticker-track"><%tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});%></div></div></div></div><%}%>
<%- include('../partials/navbar') %>
<main>
<section class="breadcrumb-section"><div class="container"><h1 class="breadcrumb-title"><%=title%></h1><ul class="breadcrumb-nav"><li><a href="/">হোম</a></li><li><%=title%></li></ul></div></section>
<section class="section"><div class="container">
  <div class="row g-4">
    <% if(students&&students.length>0){ students.forEach(s=>{ %>
    <div class="col-lg-3 col-md-4 col-6 reveal">
      <div class="teacher-card">
        <div class="teacher-img-wrap" style="height:200px">
          <img src="<%= s.imageUrl||'/images/teacher-default.jpg' %>" alt="<%= s.name %>" onerror="this.src='/images/teacher-default.jpg'"/>
        </div>
        <div class="teacher-info">
          <div class="teacher-name"><%= s.name %></div>
          <div class="teacher-desig"><%= s.course||'' %></div>
          <div style="font-size:.77rem;color:var(--gray-500);margin-top:4px"><%= s.session||'' %></div>
          <% if(s.regNo){ %><div style="font-size:.75rem;background:rgba(30,144,255,.08);color:var(--blue);padding:3px 10px;border-radius:12px;display:inline-block;margin-top:6px;font-weight:600">Reg: <%= s.regNo %></div><%}%>
        </div>
      </div>
    </div>
    <% }); } else { %>
    <div class="col-12 text-center py-5 text-muted"><i class="bi bi-people fs-1 d-block mb-3 opacity-25"></i><p>শিক্ষার্থীদের তথ্য এখনো যোগ করা হয়নি।</p></div>
    <% } %>
  </div>
</div></section>
</main>
<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body></html>
