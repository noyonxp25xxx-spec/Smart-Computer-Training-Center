<!DOCTYPE html><html lang="bn"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title><%= title %> | <%= site.name %></title><link rel="icon" href="<%= site.faviconUrl||'/images/favicon.png' %>"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="/css/style.css"/>
<link rel="stylesheet" href="/css/print.css" media="print"/>
<style>.reveal{opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease}.reveal.revealed{opacity:1;transform:none}</style>
</head><body>
<% if(tickerNotices&&tickerNotices.length>0){%><div class="notice-ticker"><div class="d-flex align-items-center"><span class="ticker-label"><i class="bi bi-bell-fill me-1"></i>নোটিশ</span><div class="ticker-wrap"><div class="ticker-track"><%tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});%></div></div></div></div><%}%>
<%- include('../partials/navbar') %>
<main>
<section class="breadcrumb-section"><div class="container"><h1 class="breadcrumb-title"><%=title%></h1><ul class="breadcrumb-nav"><li><a href="/">হোম</a></li><li><%=title%></li></ul></div></section>

<!-- RESULT SEARCH HERO -->
<section class="result-hero">
  <div class="container">
    <p style="color:rgba(255,255,255,.6);margin-bottom:30px;font-size:1rem">রেজিস্ট্রেশন নম্বর দিয়ে আপনার পরীক্ষার ফলাফল দেখুন</p>
    <div class="result-search-wrap">
      <form id="resultSearchForm">
        <label style="color:rgba(255,255,255,.8);font-size:.9rem;font-weight:600;display:block;margin-bottom:10px;">
          <i class="bi bi-person-badge me-2"></i>রেজিস্ট্রেশন নম্বর লিখুন
        </label>
        <input type="text" id="regNoInput" class="result-input" placeholder="যেমন: SCT-2024-001" required autocomplete="off" />
        <button type="submit" class="btn-result-search">
          <i class="bi bi-search me-2"></i>ফলাফল দেখুন
        </button>
      </form>
      <div id="resultError" class="alert-custom alert-error-custom mt-3 d-none"></div>
    </div>
    <!-- Spinner -->
    <div id="resultSpinner" style="display:none;margin-top:30px;"><div class="spinner"></div><p style="color:rgba(255,255,255,.6);text-align:center;font-size:.9rem">লোড হচ্ছে...</p></div>
  </div>
</section>

<!-- MARKSHEET RESULT -->
<section class="section" style="background:var(--gray-50)">
  <div class="container">
    <div id="resultBox" class="d-none">
      <div class="marksheet">
        <div class="marksheet-header">
          <div class="d-flex align-items-center justify-content-center gap-3 mb-3">
            <img src="<%= site.logoUrl||'/images/default-logo.png' %>" alt="Logo" style="height:50px;border-radius:8px;background:rgba(255,255,255,.1);padding:4px"/>
            <div>
              <div class="org-name"><%= site.name %></div>
              <div style="font-size:.78rem;opacity:.75"><%= site.address||'' %></div>
            </div>
          </div>
          <div class="result-title">📋 পরীক্ষার ফলাফল</div>
        </div>
        <div class="marksheet-body">
          <div class="student-info-grid">
            <div class="info-row"><span class="info-label">শিক্ষার্থীর নাম</span><span class="info-value" id="ms-name">—</span></div>
            <div class="info-row"><span class="info-label">রেজিস্ট্রেশন নম্বর</span><span class="info-value" id="ms-regno">—</span></div>
            <div class="info-row"><span class="info-label">রোল নম্বর</span><span class="info-value" id="ms-roll">—</span></div>
            <div class="info-row"><span class="info-label">কোর্সের নাম</span><span class="info-value" id="ms-course">—</span></div>
            <div class="info-row"><span class="info-label">সেশন</span><span class="info-value" id="ms-session">—</span></div>
            <div class="info-row"><span class="info-label">পিতার নাম</span><span class="info-value" id="ms-father">—</span></div>
            <div class="info-row"><span class="info-label">ফলাফল প্রকাশের তারিখ</span><span class="info-value" id="ms-publish">—</span></div>
          </div>

          <table class="subject-table">
            <thead>
              <tr>
                <th>#</th>
                <th>বিষয়</th>
                <th>নম্বর</th>
                <th>গ্রেড</th>
              </tr>
            </thead>
            <tbody id="ms-subjects"></tbody>
          </table>

          <div class="result-verdict">
            <div>
              <div class="gpa-label">মোট GPA / গ্রেড</div>
              <div class="gpa-display" id="ms-gpa">—</div>
            </div>
            <div id="ms-verdict" class="verdict-pass">—</div>
          </div>

          <div class="text-center mt-4 no-print">
            <button class="btn-print" id="btnPrint"><i class="bi bi-printer"></i> প্রিন্ট / PDF সংরক্ষণ</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Empty state -->
    <div class="text-center py-5" id="resultEmptyState">
      <div style="font-size:4rem;opacity:.2;margin-bottom:16px">📋</div>
      <p style="color:var(--gray-500)">রেজিস্ট্রেশন নম্বর দিয়ে ফলাফল খুঁজুন</p>
    </div>
  </div>
</section>

</main>
<%- include('../partials/footer') %>
<div class="alert-placeholder" style="position:fixed;top:20px;left:50%;transform:translateX(-50%);z-index:9999;width:90%;max-width:500px;"></div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
<script>
// Hide empty state when result shown
document.getElementById('resultSearchForm').addEventListener('submit', () => {
  document.getElementById('resultEmptyState').style.display = 'none';
});
</script>
</body></html>
