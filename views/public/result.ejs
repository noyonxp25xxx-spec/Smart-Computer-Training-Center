<!DOCTYPE html><html lang="bn"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('../partials/seo-head') %>

"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="/css/style.css"/>
<link rel="stylesheet" href="/css/print.css" media="print"/>
<style>.reveal{opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease}.reveal.revealed{opacity:1;transform:none}</style>
</head><body>
<% if(tickerNotices&&tickerNotices.length>0){%><div class="notice-ticker"><div class="d-flex align-items-center"><span class="ticker-label"><i class="bi bi-bell-fill me-1"></i>নোটিশ</span><div class="ticker-wrap"><div class="ticker-track"><%tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});%></div></div></div></div><%}%>
<%- include('../partials/navbar') %>
<main>
<section class="breadcrumb-section"><div class="container"><h1 class="breadcrumb-title"><%=title%></h1><ul class="breadcrumb-nav"><li><a href="/">হোম</a></li><li><%=title%></li></ul></div></section>
<!-- RESULT SEARCH HERO -->
<section class="result-hero">
  <div class="container">
    <p style="color:rgba(255,255,255,.6);margin-bottom:30px;font-size:1rem">রেজিস্ট্রেশন নম্বর দিয়ে আপনার পরীক্ষার ফলাফল দেখুন</p>
    <div class="result-search-wrap">
      <form id="resultSearchForm">
        <label style="color:rgba(255,255,255,.8);font-size:.9rem;font-weight:600;display:block;margin-bottom:10px;">
          <i class="bi bi-person-badge me-2"></i>রেজিস্ট্রেশন নম্বর লিখুন
        </label>
        <input type="text" id="regNoInput" class="result-input" placeholder="যেমন: 111111" required autocomplete="off" />
        <button type="submit" class="btn-result-search">
          <i class="bi bi-search me-2"></i>ফলাফল দেখুন
        </button>
      </form>
      <div id="resultError" class="alert-custom alert-error-custom mt-3 d-none"></div>
    </div>
    <!-- Spinner -->
    <div id="resultSpinner" style="display:none;margin-top:30px;"><div class="spinner"></div><p style="color:rgba(255,255,255,.6);text-align:center;font-size:.9rem">লোড হচ্ছে...</p></div>
  </div>
</section>
<!-- MARKSHEET RESULT -->
<section class="section" style="background:var(--gray-50)">
  <div class="container">
    <div id="resultBox" class="d-none">
      <div class="marksheet">
        <div class="marksheet-header">
          <div class="d-flex align-items-center justify-content-center gap-3 mb-3">
            <img src="<%= site.logoUrl||'/images/default-logo.png' %>" alt="Logo" style="height:50px;border-radius:8px;background:rgba(255,255,255,.1);padding:4px"/>
            <div>
              <div class="org-name"><%= site.name %></div>
              <div style="font-size:.78rem;opacity:.75"><%= site.address||'' %></div>
            </div>
          </div>
          <div class="result-title">📋 পরীক্ষার ফলাফল</div>
        </div>
        <div class="marksheet-body">
          <div class="student-info-grid">
            <div class="info-row"><span class="info-label">শিক্ষার্থীর নাম</span><span class="info-value" id="ms-name">—</span></div>
            <div class="info-row"><span class="info-label">রেজিস্ট্রেশন নম্বর</span><span class="info-value" id="ms-regno">—</span></div>
            <div class="info-row"><span class="info-label">রোল নম্বর</span><span class="info-value" id="ms-roll">—</span></div>
            <div class="info-row"><span class="info-label">কোর্সের নাম</span><span class="info-value" id="ms-course">—</span></div>
            <div class="info-row"><span class="info-label">সেশন</span><span class="info-value" id="ms-session">—</span></div>
            <div class="info-row"><span class="info-label">পিতার নাম</span><span class="info-value" id="ms-father">—</span></div>
            <div class="info-row"><span class="info-label">ফলাফল প্রকাশের তারিখ</span><span class="info-value" id="ms-publish">—</span></div>
          </div>
          <div id="ms-table-container" style="display:none; margin-top:24px;">
            <table class="subject-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>বিষয়</th>
                  <th>নম্বর</th>
                  <th>গ্রেড</th>
                </tr>
              </thead>
              <tbody id="ms-subjects"></tbody>
            </table>
            <div class="result-verdict">
              <div>
                <div class="gpa-label">মোট GPA / গ্রেড</div>
                <div class="gpa-display" id="ms-gpa">—</div>
              </div>
              <div id="ms-verdict" class="verdict-pass">—</div>
            </div>
          </div>
          <div id="pfBannerContainer" style="display:none; text-align: center; border-radius: 12px; padding: 24px; margin-bottom: 24px;">
            <i id="pfBannerIcon" class="bi" style="font-size: 3rem; margin-bottom: 12px; display: inline-block;"></i>
            <h4 id="pfBannerTitle" style="font-weight: 700; margin-bottom: 8px;"></h4>
            <p id="pfBannerText" style="font-size: 0.95rem; margin-bottom: 0;"></p>
          </div>
          <div id="resultPaymentContainer" style="display:none; margin-top: 30px; border: 2px dashed #dc2626; padding: 20px; border-radius: 8px; background: #fff5f5;">
            <h4 style="color: #dc2626; font-size: 1.1rem; font-weight: 700; margin-top: 0; margin-bottom: 15px;">Payment Instructions / পেমেন্ট নির্দেশিকা</h4>
            <div style="background: #fff; border: 1px solid #fca5a5; border-radius: 8px; padding: 15px; margin-bottom: 12px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
              <div style="font-weight: 700; color: #dc2626; font-size: 1.05rem; margin-bottom: 8px;">সার্টিফিকেট ডাউনলোড করতে পেমেন্ট করুন।</div>
              <div style="margin-bottom: 12px; font-size: 0.95rem; color: #333; line-height: 1.5;">
                <strong>পেমেন্ট মেথড:</strong> <%= site.paymentMethods || 'বিকাশ/নগদ/রকেট' %><br>
                <strong>সার্টিফিকেট ফি:</strong> <span style="font-weight: 800; color: #16a34a; font-size: 1.1rem;"><%= site.resultPaymentAmount || '200 ৳' %></span>
              </div>
              <div style="display: flex; align-items: center; gap: 10px; background: #f8fafc; padding: 10px; border-radius: 6px; border: 1px solid #e2e8f0; margin-bottom: 12px;">
                <span style="font-weight: 600; color: #475569;">নাম্বার:</span>
                <span id="payNumber" style="font-weight: 800; font-size: 1.15rem; color: #0f172a; letter-spacing: 1px;"><%= site.paymentNumber || '01774542513' %></span>
                <button type="button" onclick="copyPaymentNumber()" class="btn btn-sm btn-outline-secondary" style="padding: 2px 8px; font-size: 0.8rem; border-radius: 4px;" title="নাম্বার কপি করুন">
                  <i class="bi bi-clipboard"></i> কপি
                </button>
              </div>
              <div style="background: #fffbeb; border-left: 4px solid #f59e0b; padding: 10px; border-radius: 4px;">
                <div style="font-size: 0.9rem; color: #b45309; font-weight: 600;">
                  <i class="bi bi-exclamation-triangle-fill me-1"></i> রেফারেন্স (Reference) হিসেবে অবশ্যই আপনার <strong style="text-decoration: underline;">রেজিস্ট্রেশন নম্বর</strong> দিবেন, অ্যাপ্লিকেশন আইডি নয়!
                </div>
              </div>
            </div>
          </div>
          <script>
            function copyPaymentNumber() {
              const num = document.getElementById('payNumber').innerText;
              navigator.clipboard.writeText(num).then(() => {
                const btn = document.querySelector('button[onclick="copyPaymentNumber()"]');
                const oldHTML = btn.innerHTML;
                btn.innerHTML = '<i class="bi bi-check-lg"></i> কপিড!';
                btn.classList.remove('btn-outline-secondary');
                btn.classList.add('btn-success');
                setTimeout(() => {
                  btn.innerHTML = oldHTML;
                  btn.classList.add('btn-outline-secondary');
                  btn.classList.remove('btn-success');
                }, 2000);
              });
            }
          </script>
          <div id="certificateContainer" style="display:none;">
            <h5 style="color:var(--admin-navy); font-weight:600; margin-bottom:12px; border-bottom:1px solid #eee; padding-bottom:10px;">
              <i class="bi bi-file-earmark-pdf-fill me-2" style="color:var(--red);"></i>আপনার সার্টিফিকেট
            </h5>
            <!-- PDF Live Preview -->
            <div style="width: 100%; aspect-ratio: 1.414 / 1; max-height: 700px; border: 1px solid #ddd; border-radius: 8px; overflow: hidden; margin-bottom: 16px;">
              <iframe id="pdfPreviewIframe" src="" width="100%" height="100%" style="border: none; min-width: 100%;"></iframe>
            </div>
            <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
              <button id="btnPrintCert" onclick="printCertificate()" class="btn btn-outline-primary" style="padding: 10px 24px; font-weight: 600; border-radius: 8px; min-width: 140px;">
                <i class="bi bi-printer-fill me-2"></i> প্রিন্ট করুন
              </button>
              <a href="#" id="btnDownloadCert" onclick="forceDownloadCert(event)" class="btn btn-primary" style="padding: 10px 24px; font-weight: 600; border-radius: 8px; box-shadow: 0 4px 15px rgba(30,144,255,0.3); min-width: 140px;">
                <i class="bi bi-cloud-arrow-down-fill me-2"></i> পিডিএফ ডাউনলোড
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Empty state -->
    <div class="text-center py-5" id="resultEmptyState">
      <div style="font-size:4rem;opacity:.2;margin-bottom:16px">📋</div>
      <p style="color:var(--gray-500)">রেজিস্ট্রেশন নম্বর দিয়ে ফলাফল খুঁজুন</p>
    </div>
  </div>
</section>
</main>
<%- include('../partials/footer') %>
<div class="alert-placeholder" style="position:fixed;top:20px;left:50%;transform:translateX(-50%);z-index:9999;width:90%;max-width:500px;"></div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
<script>
// Hide empty state when result shown
document.getElementById('resultSearchForm').addEventListener('submit', () => {
  document.getElementById('resultEmptyState').style.display = 'none';
});
async function printCertificate() {
  const url = document.getElementById('btnDownloadCert').href;
  if(!url || url === '#' || url.endsWith('#')) return;
  const btn = document.getElementById('btnPrintCert');
  const originalText = btn.innerHTML;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> প্রস্তুত হচ্ছে...';
  btn.disabled = true;
  try {
    const response = await fetch(url);
    const blob = await response.blob();
    const blobUrl = URL.createObjectURL(blob);
    const iframe = document.createElement('iframe');
    iframe.style.display = 'none';
    iframe.src = blobUrl;
    document.body.appendChild(iframe);
    iframe.onload = function() {
      setTimeout(() => {
        iframe.contentWindow.focus();
        iframe.contentWindow.print();
        btn.innerHTML = originalText;
        btn.disabled = false;
        // Optionally remove after printing: document.body.removeChild(iframe);
      }, 500);
    };
  } catch(e) {
    console.error('Direct print failed, falling back to new window', e);
    const printWindow = window.open(url, '_blank');
    if (printWindow) {
      printWindow.onload = function() {
        try { printWindow.print(); } catch(err) {}
      };
    }
    btn.innerHTML = originalText;
    btn.disabled = false;
  }
}
async function forceDownloadCert(e) {
  e.preventDefault();
  const url = e.currentTarget.href;
  if(!url || url === '#' || url.endsWith('#')) return;
  const btn = e.currentTarget;
  const originalText = btn.innerHTML;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> ডাউনলোড হচ্ছে...';
  btn.style.pointerEvents = 'none';
  try {
    const response = await fetch(url);
    const blob = await response.blob();
    const blobUrl = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = blobUrl;
    const regNo = document.getElementById('ms-regno').textContent || 'Certificate';
    a.download = `Certificate_${regNo}.pdf`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(blobUrl);
  } catch(err) {
    console.error('Direct download failed, opening in new tab', err);
    window.open(url, '_blank');
  } finally {
    btn.innerHTML = originalText;
    btn.style.pointerEvents = 'auto';
  }
}
</script>
</body></html>
