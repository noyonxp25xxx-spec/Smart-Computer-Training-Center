<!DOCTYPE html><html lang="bn"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('../partials/seo-head') %>

"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="/css/style.css"/>
<style>.reveal{opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease}.reveal.revealed{opacity:1;transform:none}</style>
</head><body>
<% if(tickerNotices&&tickerNotices.length>0){%><div class="notice-ticker"><div class="d-flex align-items-center"><span class="ticker-label"><i class="bi bi-bell-fill me-1"></i>নোটিশ</span><div class="ticker-wrap"><div class="ticker-track"><%tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});%></div></div></div></div><%}%>
<%- include('../partials/navbar') %>
<main>
<section class="breadcrumb-section"><div class="container"><h1 class="breadcrumb-title"><%=title%></h1><ul class="breadcrumb-nav"><li><a href="/">হোম</a></li><li><%=title%></li></ul></div></section>
<section class="section">
  <div class="container">
    <div class="table-responsive reveal">
      <table class="table table-hover align-middle" style="background:#fff;border-radius:16px;overflow:hidden;box-shadow:var(--shadow-md)">
        <thead style="background:var(--navy);color:#fff">
          <tr>
            <th style="padding:16px 20px">#</th>
            <th style="padding:16px 20px">ছবি</th>
            <th style="padding:16px 20px">নাম</th>
            <th style="padding:16px 20px">পদবি</th>
          </tr>
        </thead>
        <tbody>
          <% if(members&&members.length>0){ members.forEach((m,i)=>{ %>
          <tr>
            <td style="padding:14px 20px;color:var(--gray-500)"><%= i+1 %></td>
            <td style="padding:14px 20px"><img src="<%= m.imageUrl||'/images/teacher-default.jpg' %>" alt="<%= m.name %>" style="width:50px;height:50px;border-radius:50%;object-fit:cover;border:3px solid var(--gray-100)" onerror="this.onerror=null;this.src='/images/teacher-default.jpg'"/></td>
            <td style="padding:14px 20px;font-weight:600;color:var(--navy)"><%= m.name %></td>
            <td style="padding:14px 20px"><span style="background:rgba(30,144,255,.1);color:var(--blue);padding:4px 14px;border-radius:20px;font-size:.83rem;font-weight:600"><%= m.designation %></span></td>
          </tr>
          <% }); } else { %>
          <tr><td colspan="4" class="text-center py-5 text-muted">কমিটির তথ্য এখনো যোগ করা হয়নি।</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</section>
</main>
<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body></html>
