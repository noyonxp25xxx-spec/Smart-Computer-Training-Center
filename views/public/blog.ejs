<!DOCTYPE html><html lang="bn"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('../partials/seo-head') %>


<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="/css/style.css"/>
<style>.reveal{opacity:0;transform:translateY(24px);transition:.6s ease}.reveal.revealed{opacity:1;transform:none}</style>
</head><body>
<% if(tickerNotices&&tickerNotices.length>0){%><div class="notice-ticker"><div class="d-flex align-items-center"><span class="ticker-label"><i class="bi bi-bell-fill me-1"></i>নোটিশ</span><div class="ticker-wrap"><div class="ticker-track"><%tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});%></div></div></div></div><%}%>
<%- include('../partials/navbar') %>
<main>
<section class="breadcrumb-section"><div class="container"><h1 class="breadcrumb-title"><%=title%></h1><ul class="breadcrumb-nav"><li><a href="/">হোম</a></li><li><%=title%></li></ul></div></section>
<section class="section"><div class="container">
  <div class="row g-4">
    <% if(posts&&posts.length>0){ posts.forEach(p=>{ %>
    <div class="col-lg-4 col-md-6 reveal">
      <div class="course-card">
        <div class="course-card-img"><img src="<%= p.imageUrl||'/images/blog-default.jpg' %>" alt="<%= p.title %>"/></div>
        <div class="course-card-body">
          <div class="course-meta"><span><i class="bi bi-calendar3"></i> <%= p.date||'' %></span><span><i class="bi bi-person"></i> <%= p.author||'Admin' %></span></div>
          <h3 class="course-card-title"><%= p.title %></h3>
          <p class="course-card-desc"><%= (p.content||'').replace(/<[^>]*>/g,'').substring(0,110) %>...</p>
          <a href="/blog/<%= p.id %>" class="btn-course">পুরো পড়ুন <i class="bi bi-arrow-right"></i></a>
        </div>
      </div>
    </div>
    <% }); } else { %>
    <div class="col-12 text-center py-5 text-muted"><i class="bi bi-journal fs-1 d-block mb-3 opacity-25"></i><p>এখনো কোনো পোস্ট নেই।</p></div>
    <% } %>
  </div>
</div></section>
</main>
<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body></html>
