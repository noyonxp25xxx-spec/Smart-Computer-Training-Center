<!DOCTYPE html><html lang="bn"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title><%= title %> | <%= site.name %></title><link rel="icon" href="<%= site.faviconUrl||'/images/favicon.png' %>"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="/css/style.css"/>
<style>.reveal{opacity:0;transform:translateY(24px);transition:.6s ease}.reveal.revealed{opacity:1;transform:none}</style>
</head><body>
<% if(tickerNotices&&tickerNotices.length>0){%><div class="notice-ticker"><div class="d-flex align-items-center"><span class="ticker-label"><i class="bi bi-bell-fill me-1"></i>নোটিশ</span><div class="ticker-wrap"><div class="ticker-track"><%tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});%></div></div></div></div><%}%>
<%- include('../partials/navbar') %>
<main>
<section class="breadcrumb-section"><div class="container"><h1 class="breadcrumb-title"><%=title%></h1><ul class="breadcrumb-nav"><li><a href="/">হোম</a></li><li><%=title%></li></ul></div></section>
<section class="section"><div class="container">
  <% if(items&&items.length>0){ %>
  <div class="gallery-grid">
    <% items.forEach(item=>{ %>
    <div class="gallery-item reveal" data-src="<%= item.url %>">
      <% if(item.type==='video'){ %>
      <video src="<%= item.url %>" style="width:100%;height:100%;object-fit:cover"></video>
      <% } else { %>
      <img src="<%= item.url %>" alt="<%= item.caption||'Gallery' %>" loading="lazy"/>
      <% } %>
      <div class="gallery-overlay"><i class="bi bi-zoom-in"></i></div>
      <% if(item.caption){ %><div style="position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(10,22,40,.85));color:#fff;padding:12px;font-size:.8rem"><%=item.caption%></div><%}%>
    </div>
    <% }); %>
  </div>
  <% } else { %>
  <div class="text-center py-5 text-muted"><i class="bi bi-images fs-1 d-block mb-3 opacity-25"></i><p>গ্যালারিতে এখনো কোনো ছবি নেই।</p></div>
  <% } %>
</div></section>
</main>
<div class="lightbox" id="lightbox"><button class="lightbox-close" id="lightboxClose">&times;</button><img src="" id="lightboxImg" alt=""/></div>
<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body></html>
