<!DOCTYPE html><html lang="bn"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('../partials/seo-head') %>


<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="/css/style.css"/>
</head><body>
<% if(tickerNotices&&tickerNotices.length>0){%><div class="notice-ticker"><div class="d-flex align-items-center"><span class="ticker-label"><i class="bi bi-bell-fill me-1"></i>নোটিশ</span><div class="ticker-wrap"><div class="ticker-track"><%tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});%></div></div></div></div><%}%>
<%- include('../partials/navbar') %>
<main>
<section class="breadcrumb-section"><div class="container"><h1 class="breadcrumb-title"><%= course.name %></h1><ul class="breadcrumb-nav"><li><a href="/">হোম</a></li><li><a href="/courses">কোর্স</a></li><li><%= course.name %></li></ul></div></section>
<section class="section"><div class="container">
  <div class="row g-5">
    <div class="col-lg-8">
      <% if(course.imageUrl){ %><img src="<%= course.imageUrl %>" alt="<%= course.name %>" class="img-fluid rounded-3 w-100 mb-4" style="max-height:450px;object-fit:contain;background:#f1f5f9;padding:10px;"/><%}%>
      <div style="background:#fff;border-radius:16px;padding:32px;box-shadow:var(--shadow-sm)">
        <h2 style="color:var(--navy);font-weight:800;margin-bottom:16px"><%= course.name %></h2>
        <div style="color:var(--gray-500);line-height:2"><%- (course.description||'কোর্সের বিবরণ পাওয়া যায়নি।').replace(/\n/g,'<br>') %></div>
      </div>
    </div>
    <div class="col-lg-4">
      <div style="background:var(--navy);border-radius:16px;padding:28px;color:#fff;position:sticky;top:90px">
        <h4 style="font-weight:700;margin-bottom:20px;color:var(--gold)">কোর্সের তথ্য</h4>
        <div style="border-bottom:1px solid rgba(255,255,255,.1);padding:12px 0;display:flex;justify-content:space-between"><span style="color:rgba(255,255,255,.6)">কোর্স কোড</span><span style="font-weight:700"><%= course.code||'—' %></span></div>
        <% if(course.durations && course.durations.length > 0) { %>
          <% course.durations.forEach((d, i) => { %>
            <div style="border-bottom:1px solid rgba(255,255,255,.1);padding:12px 0;display:flex;justify-content:space-between">
              <span style="color:rgba(255,255,255,.6)">মেয়াদ: <%= d.duration %></span>
              <span style="font-weight:700;color:var(--gold)">৳ <%= d.fee %></span>
            </div>
          <% }); %>
        <% } else { %>
          <div style="border-bottom:1px solid rgba(255,255,255,.1);padding:12px 0;display:flex;justify-content:space-between"><span style="color:rgba(255,255,255,.6)">মেয়াদ</span><span style="font-weight:700"><%= course.duration||'—' %></span></div>
          <div style="border-bottom:1px solid rgba(255,255,255,.1);padding:12px 0;display:flex;justify-content:space-between"><span style="color:rgba(255,255,255,.6)">ফি</span><span style="font-weight:700;color:var(--gold)">৳ <%= course.fee||'—' %></span></div>
        <% } %>
        <a href="/admission" class="btn-hero-primary d-block text-center mt-4"><i class="bi bi-pen me-2"></i>ভর্তি হন</a>
        <a href="/contact" class="btn-hero-secondary d-block text-center mt-3"><i class="bi bi-telephone me-2"></i>যোগাযোগ করুন</a>
      </div>
    </div>
  </div>
</div></section>
</main>
<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body></html>
