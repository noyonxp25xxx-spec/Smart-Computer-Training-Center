<!DOCTYPE html><html lang="bn"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('../partials/seo-head') %>


<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="/css/style.css"/>
<style>.reveal{opacity:0;transform:translateY(24px);transition:.6s ease}.reveal.revealed{opacity:1;transform:none}</style>
</head><body>
<% if(tickerNotices&&tickerNotices.length>0){%><div class="notice-ticker"><div class="d-flex align-items-center"><span class="ticker-label"><i class="bi bi-bell-fill me-1"></i>নোটিশ</span><div class="ticker-wrap"><div class="ticker-track"><%tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});%></div></div></div></div><%}%>
<%- include('../partials/navbar') %>
<main>
<section class="breadcrumb-section"><div class="container"><h1 class="breadcrumb-title"><%=title%></h1><ul class="breadcrumb-nav"><li><a href="/">হোম</a></li><li><%=title%></li></ul></div></section>
<section class="section"><div class="container">
  <div class="row g-4">
    <% if(notices&&notices.length>0){ notices.forEach(n=>{ %>
    <div class="col-12 reveal">
      <div class="notice-card">
        <div class="notice-date-box">
          <div class="day"><%= n.date ? new Date(n.date).getDate() : '—' %></div>
          <div class="month"><%= n.date ? new Date(n.date).toLocaleString('bn-BD',{month:'short'}) : '' %></div>
        </div>
        <div style="flex:1">
          <div class="notice-title" style="font-size:1rem"><%= n.title %></div>
          <div class="notice-body"><%= n.body||'' %></div>
        </div>
      </div>
    </div>
    <% }); } else { %>
    <div class="col-12 text-center py-5 text-muted"><i class="bi bi-bell-slash fs-1 d-block mb-3 opacity-25"></i><p>এখনো কোনো নোটিশ নেই।</p></div>
    <% } %>
  </div>
</div></section>
</main>
<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body></html>
