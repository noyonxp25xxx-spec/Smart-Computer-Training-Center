<!DOCTYPE html><html lang="bn"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title><%= title %> | <%= site.name %></title><link rel="icon" href="<%= site.faviconUrl||'/images/favicon.png' %>"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="/css/style.css"/>
<style>.reveal{opacity:0;transform:translateY(24px);transition:.6s ease}.reveal.revealed{opacity:1;transform:none}</style>
</head><body>
<% if(tickerNotices&&tickerNotices.length>0){%><div class="notice-ticker"><div class="d-flex align-items-center"><span class="ticker-label"><i class="bi bi-bell-fill me-1"></i>নোটিশ</span><div class="ticker-wrap"><div class="ticker-track"><%tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});%></div></div></div></div><%}%>
<%- include('../partials/navbar') %>
<main>
<section class="breadcrumb-section"><div class="container"><h1 class="breadcrumb-title"><%=title%></h1><ul class="breadcrumb-nav"><li><a href="/">হোম</a></li><li><%=title%></li></ul></div></section>
<section class="section"><div class="container">
  <div class="row g-4">
    <% if(courses&&courses.length>0){ courses.forEach(c=>{ %>
    <div class="col-6 col-md-6 col-lg-4 reveal">
      <div class="course-card">
        <div class="course-card-img">
          <img src="<%= c.imageUrl||'/images/course-default.jpg' %>" alt="<%= c.name %>" onerror="this.style.display='none'"/>
          <% if(c.code){%><span class="course-badge"><%=c.code%></span><%}%>
        </div>
        <div class="course-card-body">
          <h3 class="course-card-title"><%= c.name %></h3>
          <div class="course-meta fw-bold text-primary mb-3" style="font-size: .95rem; gap: 20px;">
            <% 
              let durText = c.duration || '';
              let feeText = c.fee ? '৳' + c.fee : '';
              if (c.durations && c.durations.length > 0) {
                durText = c.durations.map(d => d.duration).join(', ');
                if (c.durations.length === 1) feeText = '৳' + c.durations[0].fee;
                else {
                  const fees = c.durations.map(d => d.fee);
                  const minFee = Math.min(...fees);
                  const maxFee = Math.max(...fees);
                  feeText = minFee === maxFee ? '৳' + minFee : '৳' + minFee + ' - ৳' + maxFee;
                }
              }
            %>
            <% if(durText) { %><span><i class="bi bi-clock me-1"></i> <%= durText %></span><% } %>
            <% if(feeText) { %><span><%= feeText %></span><% } %>
          </div>
          <a href="/courses/<%= c.id %>" class="btn-course">বিস্তারিত দেখুন <i class="bi bi-arrow-right"></i></a>
        </div>
      </div>
    </div>
    <% }); } else { %>
    <div class="col-12 text-center py-5 text-muted"><i class="bi bi-book fs-1 d-block mb-3 opacity-25"></i><p>এখনো কোনো কোর্স যোগ করা হয়নি।</p></div>
    <% } %>
  </div>
</div></section>
</main>
<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body></html>
