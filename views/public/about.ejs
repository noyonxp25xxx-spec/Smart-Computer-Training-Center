<%
// Shared head/body wrapper for all inner public pages
// Usage: include this or use a layout engine
%>
<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('../partials/seo-head') %>

  " />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>.reveal{opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease}.reveal.revealed{opacity:1;transform:none}</style>
</head>
<body>
<% if (tickerNotices && tickerNotices.length > 0) { %>
<div class="notice-ticker"><div class="d-flex align-items-center"><span class="ticker-label"><i class="bi bi-bell-fill me-1"></i> নোটিশ</span><div class="ticker-wrap"><div class="ticker-track"><% tickerNotices.forEach(n => { %><span><%= n.title %></span><% }); tickerNotices.forEach(n => { %><span><%= n.title %></span><% }); %></div></div></div></div>
<% } %>
<%- include('../partials/navbar') %>
<main>
<!-- BREADCRUMB -->
<section class="breadcrumb-section">
  <div class="container">
    <h1 class="breadcrumb-title"><%= title %></h1>
    <ul class="breadcrumb-nav">
      <li><a href="/">হোম</a></li>
      <li><%= title %></li>
    </ul>
  </div>
</section>
<!-- ABOUT CONTENT -->
<section class="section">
  <div class="container">
    <div class="row g-5 align-items-center">
      <div class="col-lg-6 reveal">
        <div class="section-title">আমাদের পরিচিতি</div>
        <div class="section-line"></div>
        <p><%= about.history || 'আমাদের প্রতিষ্ঠান সম্পর্কে বিস্তারিত তথ্য Admin Panel থেকে আপডেট করুন।' %></p>
      </div>
      <div class="col-lg-6 reveal">
        <% if(about.imageUrl) { %>
        <img src="<%= about.imageUrl %>" alt="প্রতিষ্ঠান" class="img-fluid rounded-3 shadow" />
        <% } else { %>
        <div style="background:linear-gradient(135deg,#0A1628,#1E90FF);border-radius:16px;height:300px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:4rem;">🏫</div>
        <% } %>
      </div>
    </div>
    <div class="row g-4 mt-5">
      <div class="col-md-4 reveal">
        <div class="course-card p-4 text-center">
          <div style="font-size:2.5rem;margin-bottom:12px;">🏗️</div>
          <h4 style="color:var(--navy);font-weight:700;margin-bottom:8px;">অবকাঠামো</h4>
          <p style="color:var(--gray-500);font-size:.9rem"><%= about.infrastructure || 'আধুনিক কম্পিউটার ল্যাব, এয়ার কন্ডিশন শ্রেণিকক্ষ।' %></p>
        </div>
      </div>
      <div class="col-md-4 reveal">
        <div class="course-card p-4 text-center">
          <div style="font-size:2.5rem;margin-bottom:12px;">📋</div>
          <h4 style="color:var(--navy);font-weight:700;margin-bottom:8px;">কার্যক্রম</h4>
          <p style="color:var(--gray-500);font-size:.9rem"><%= about.activities || 'নিয়মিত ক্লাস, পরীক্ষা ও সার্টিফিকেট প্রদান।' %></p>
        </div>
      </div>
      <div class="col-md-4 reveal">
        <div class="course-card p-4 text-center">
          <div style="font-size:2.5rem;margin-bottom:12px;">🎯</div>
          <h4 style="color:var(--navy);font-weight:700;margin-bottom:8px;">লক্ষ্য ও উদ্দেশ্য</h4>
          <p style="color:var(--gray-500);font-size:.9rem"><%= about.mission || 'দক্ষ মানবসম্পদ তৈরি করে দেশের আইটি খাতে অবদান রাখা।' %></p>
        </div>
      </div>
    </div>
  </div>
</section>
</main>
<%- include('../partials/footer') %>
<div class="alert-placeholder" style="position:fixed;top:20px;left:50%;transform:translateX(-50%);z-index:9999;width:90%;max-width:500px;"></div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
