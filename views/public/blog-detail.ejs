<!DOCTYPE html><html lang="bn"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('../partials/seo-head') %>


<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="/css/style.css"/>
</head><body>
<% if(tickerNotices&&tickerNotices.length>0){%><div class="notice-ticker"><div class="d-flex align-items-center"><span class="ticker-label"><i class="bi bi-bell-fill me-1"></i>নোটিশ</span><div class="ticker-wrap"><div class="ticker-track"><%tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});tickerNotices.forEach(n=>{%><span><%=n.title%></span><%});%></div></div></div></div><%}%>
<%- include('../partials/navbar') %>
<main>
<section class="breadcrumb-section"><div class="container"><h1 class="breadcrumb-title"><%= post.title %></h1><ul class="breadcrumb-nav"><li><a href="/">হোম</a></li><li><a href="/blog">ব্লগ</a></li><li><%= post.title.substring(0,30) %>...</li></ul></div></section>
<section class="section"><div class="container">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div style="background:#fff;border-radius:16px;padding:36px;box-shadow:var(--shadow-md)">
        <% if(post.imageUrl){ %><img src="<%= post.imageUrl %>" alt="<%= post.title %>" class="img-fluid rounded-3 w-100 mb-4" style="max-height:380px;object-fit:cover"/><%}%>
        <div style="display:flex;gap:16px;color:var(--gray-500);font-size:.85rem;margin-bottom:20px">
          <span><i class="bi bi-calendar3 me-1"></i><%= post.date||'' %></span>
          <span><i class="bi bi-person me-1"></i><%= post.author||'Admin' %></span>
        </div>
        <div style="line-height:2;color:var(--gray-700)"><%- post.content||'' %></div>
        <div class="mt-5 pt-4" style="border-top:1px solid var(--gray-100)">
          <a href="/blog" style="color:var(--blue);text-decoration:none;font-weight:600"><i class="bi bi-arrow-left me-2"></i>সব পোস্ট দেখুন</a>
        </div>
      </div>
    </div>
  </div>
</div></section>
</main>
<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body></html>
