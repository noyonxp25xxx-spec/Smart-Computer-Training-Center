<%
const pageTitle = title;
const pageBody = `
<!-- ── HERO SLIDER ────────────────────────────────── -->
<section class="hero-slider-wrap position-relative">
  ${sliders.length > 0 ? sliders.map((s, i) => `
  <div class="hero-slide">
    <img class="hero-bg" src="${s.imageUrl || '/images/hero-default.jpg'}" alt="${s.caption || 'Banner'}">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <div class="col-lg-7">
        <div class="hero-badge"><i class="bi bi-stars"></i> ${site.code || 'SCT-2024'}</div>
        <h1 class="hero-title">${site.name}<br><span>${site.tagline || ''}</span></h1>
        <p class="hero-subtitle">${s.caption || 'আধুনিক প্রযুক্তি শিক্ষায় আপনাকে স্বাগতম'}</p>
        <div class="hero-actions">
          <a href="/courses" class="btn-hero-primary"><i class="bi bi-mortarboard"></i> কোর্স দেখুন</a>
          <a href="/result" class="btn-hero-secondary"><i class="bi bi-search"></i> ফলাফল দেখুন</a>
        </div>
      </div>
    </div>
  </div>`).join('') : `
  <div class="hero-slide">
    <div class="hero-overlay" style="background:linear-gradient(135deg,rgba(10,22,40,.97),rgba(10,22,40,.75))"></div>
    <div class="container hero-content">
      <div class="col-lg-7">
        <div class="hero-badge"><i class="bi bi-stars"></i> ${site.code || 'SCT-2024'}</div>
        <h1 class="hero-title">${site.name}<br><span>${site.tagline || 'আধুনিক প্রযুক্তিতে দক্ষ হয়ে উঠুন'}</span></h1>
        <p class="hero-subtitle">দক্ষ শিক্ষকমণ্ডলী ও আধুনিক সিলেবাসে কম্পিউটার প্রশিক্ষণ নিন। আপনার ক্যারিয়ার গড়ুন আমাদের সাথে।</p>
        <div class="hero-actions">
          <a href="/courses" class="btn-hero-primary"><i class="bi bi-mortarboard"></i> কোর্স দেখুন</a>
          <a href="/result" class="btn-hero-secondary"><i class="bi bi-search"></i> ফলাফল দেখুন</a>
        </div>
      </div>
    </div>
  </div>`}
  <!-- Slider controls -->
  ${sliders.length > 1 ? `
  <button class="slider-arrow prev"><i class="bi bi-chevron-left"></i></button>
  <button class="slider-arrow next"><i class="bi bi-chevron-right"></i></button>
  <div class="slider-controls">
    ${sliders.map((_, i) => `<button class="slider-dot${i===0?' active':''}" aria-label="Slide ${i+1}"></button>`).join('')}
  </div>` : ''}
</section>
`;
%>
<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('../partials/seo-head') %>

  <meta name="description" content="<%= site.tagline %>" />

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>.reveal{opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease}.reveal.revealed{opacity:1;transform:none}</style>
</head>
<body>
<%- include('../partials/navbar') %>
<main>
<!-- ── HERO SLIDER ─────────────────────────────────── -->
<section class="hero-slider-wrap position-relative">
  <% if (sliders && sliders.length > 0) { sliders.forEach((s, i) => { %>
  <div class="hero-slide" style="<%= i > 0 ? 'display:none' : '' %>">
    <img class="hero-bg" src="<%= s.imageUrl || '/images/hero-default.jpg' %>" alt="<%= s.caption || 'Banner' %>" />
  </div>
  <% }); } else { %>
  <div class="hero-slide">
    <img class="hero-bg" src="/images/hero-default.jpg" alt="Default Banner" />
  </div>
  <% } %>
  <% if (sliders && sliders.length > 1) { %>
  <button class="slider-arrow prev"><i class="bi bi-chevron-left"></i></button>
  <button class="slider-arrow next"><i class="bi bi-chevron-right"></i></button>
  <div class="slider-controls">
    <% sliders.forEach((_, i) => { %><button class="slider-dot <%= i===0?'active':'' %>" aria-label="Slide <%= i+1 %>"></button><% }); %>
  </div>
  <% } %>
</section>
<!-- ── COURSES ──────────────────────────────────────── -->
<section class="section">
  <div class="container">
    <div class="text-center mb-5 reveal">
      <div class="section-title">আমাদের কোর্সসমূহ</div>
      <div class="section-line mx-auto"></div>
    </div>
    <div class="row">
      <!-- Courses Column (Left side on PC, Top on Mobile) -->
      <div class="col-lg-9 mb-4 mb-lg-0">
        <div class="row g-4">
      <% if (courses && courses.length > 0) { courses.forEach(c => { %>
      <div class="col-6 col-md-6 col-lg-4 reveal">
        <div class="course-card">
          <div class="course-card-img">
            <img src="<%= c.imageUrl || '/images/course-default.jpg' %>" alt="<%= c.name %>" onerror="this.style.display='none'" />
            <% if(c.code) { %><span class="course-badge"><%= c.code %></span><% } %>
          </div>
          <div class="course-card-body">
            <h3 class="course-card-title"><%= c.name %></h3>
            <div class="course-meta fw-bold text-primary mb-3" style="font-size: .95rem; flex-direction: column; gap: 8px;">
              <% if (c.durations && c.durations.length > 0) { %>
                <% c.durations.forEach(d => { %>
                  <div class="d-flex justify-content-between align-items-center w-100">
                    <span><i class="bi bi-clock me-1"></i> <%= d.duration %></span>
                    <span>৳<%= d.fee %></span>
                  </div>
                <% }); %>
              <% } else { %>
                <div class="d-flex justify-content-between align-items-center w-100">
                  <% if(c.duration) { %><span><i class="bi bi-clock me-1"></i> <%= c.duration %></span><% } %>
                  <% if(c.fee) { %><span>৳<%= c.fee %></span><% } %>
                </div>
              <% } %>
            </div>
            <a href="/courses/<%= c.id %>" class="btn-course">বিস্তারিত দেখুন <i class="bi bi-arrow-right"></i></a>
          </div>
        </div>
      </div>
      <% }); } else { %>
      <div class="col-12 text-center py-5 text-muted">
        <i class="bi bi-book fs-1 d-block mb-3 opacity-25"></i>
        <p>এখনো কোনো কোর্স যোগ করা হয়নি।</p>
      </div>
      <% } %>
        </div>
        <% if (courses && courses.length > 0) { %>
        <div class="text-center mt-5">
          <a href="/courses" class="btn-primary-custom">সব কোর্স দেখুন <i class="bi bi-arrow-right"></i></a>
        </div>
        <% } %>
        <!-- Web Development Banner - Premium Design -->
        <%
          let waRaw = site.whatsappNumber || '';
          let waUrlBase = waRaw;
          if(waRaw && !waRaw.startsWith('http')) {
            waUrlBase = 'https://wa.me/' + waRaw.replace(/[^\d+]/g, '');
          }
        %>
        <div class="web-dev-banner mt-5 reveal position-relative" style="background: linear-gradient(145deg, #ffffff, #f8fafc); border: 1px solid rgba(226, 232, 240, 0.8); border-radius: 20px; overflow: hidden; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.04), inset 0 1px 0 rgba(255, 255, 255, 1);">
          <div style="padding: 35px 30px 25px; text-align: center; position: relative; z-index: 1;">
            <div style="position: absolute; top: -50%; left: 50%; transform: translateX(-50%); width: 250px; height: 250px; background: rgba(30, 144, 255, 0.12); filter: blur(45px); border-radius: 50%; z-index: -1;"></div>
            <h3 style="font-weight: 800; font-size: 1.4rem; color: #0f172a; margin-bottom: 0; line-height: 1.4;">
              অভিজ্ঞ ওয়েব ডেভেলপার দ্বারা <br><span style="background: linear-gradient(135deg, var(--blue), #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">প্রফেশনাল ওয়েবসাইট</span> তৈরি করা হয়
            </h3>
          </div>
          <div style="padding: 0 30px 30px; position: relative; z-index: 1;">
            <div style="background: #ffffff; border: 1px solid #f1f5f9; border-radius: 16px; padding: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.02);">
              <div class="row g-3">
                <div class="col-md-6">
                  <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px;">
                    <li style="display: flex; align-items: center; gap: 12px; font-weight: 600; color: #334155; font-size: 0.95rem; cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='#334155'" data-bs-toggle="modal" data-bs-target="#webDevModal" onclick="document.getElementById('webDevModalLink').href='<%= waUrlBase %><%= waUrlBase.includes('?') ? '&' : '?' %>text='+encodeURIComponent('আমি স্কুল/কলেজের ওয়েবসাইট তৈরি করার বিষয়ে বিস্তারিত জানতে চাই।')">
                      <div style="display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: linear-gradient(135deg, #22c55e, #16a34a); border-radius: 50%; color: #fff; box-shadow: 0 4px 10px rgba(34, 197, 94, 0.2);"><i class="bi bi-check-lg" style="font-size: 0.9rem; stroke-width: 1px;"></i></div> স্কুল/কলেজের ওয়েবসাইট
                    </li>
                    <li style="display: flex; align-items: center; gap: 12px; font-weight: 600; color: #334155; font-size: 0.95rem; cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='#334155'" data-bs-toggle="modal" data-bs-target="#webDevModal" onclick="document.getElementById('webDevModalLink').href='<%= waUrlBase %><%= waUrlBase.includes('?') ? '&' : '?' %>text='+encodeURIComponent('আমি ব্যবসায়িক প্রতিষ্ঠানের ওয়েবসাইট তৈরি করার বিষয়ে বিস্তারিত জানতে চাই।')">
                      <div style="display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: linear-gradient(135deg, #22c55e, #16a34a); border-radius: 50%; color: #fff; box-shadow: 0 4px 10px rgba(34, 197, 94, 0.2);"><i class="bi bi-check-lg" style="font-size: 0.9rem; stroke-width: 1px;"></i></div> ব্যবসায়িক প্রতিষ্ঠানের ওয়েবসাইট
                    </li>
                    <li style="display: flex; align-items: center; gap: 12px; font-weight: 600; color: #334155; font-size: 0.95rem; cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='#334155'" data-bs-toggle="modal" data-bs-target="#webDevModal" onclick="document.getElementById('webDevModalLink').href='<%= waUrlBase %><%= waUrlBase.includes('?') ? '&' : '?' %>text='+encodeURIComponent('আমি অনলাইন ভিত্তিক প্রতিষ্ঠানের ওয়েবসাইট তৈরি করার বিষয়ে বিস্তারিত জানতে চাই।')">
                      <div style="display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: linear-gradient(135deg, #22c55e, #16a34a); border-radius: 50%; color: #fff; box-shadow: 0 4px 10px rgba(34, 197, 94, 0.2);"><i class="bi bi-check-lg" style="font-size: 0.9rem; stroke-width: 1px;"></i></div> অনলাইন ভিত্তিক প্রতিষ্ঠানের ওয়েবসাইট
                    </li>
                    <li style="display: flex; align-items: center; gap: 12px; font-weight: 600; color: #334155; font-size: 0.95rem; cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='#334155'" data-bs-toggle="modal" data-bs-target="#webDevModal" onclick="document.getElementById('webDevModalLink').href='<%= waUrlBase %><%= waUrlBase.includes('?') ? '&' : '?' %>text='+encodeURIComponent('আমি ই-কমার্স ওয়েবসাইট তৈরি করার বিষয়ে বিস্তারিত জানতে চাই।')">
                      <div style="display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: linear-gradient(135deg, #22c55e, #16a34a); border-radius: 50%; color: #fff; box-shadow: 0 4px 10px rgba(34, 197, 94, 0.2);"><i class="bi bi-check-lg" style="font-size: 0.9rem; stroke-width: 1px;"></i></div> ই-কমার্স ওয়েবসাইট
                    </li>
                  </ul>
                </div>
                <div class="col-md-6">
                  <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px;">
                    <li style="display: flex; align-items: center; gap: 12px; font-weight: 600; color: #334155; font-size: 0.95rem; cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='#334155'" data-bs-toggle="modal" data-bs-target="#webDevModal" onclick="document.getElementById('webDevModalLink').href='<%= waUrlBase %><%= waUrlBase.includes('?') ? '&' : '?' %>text='+encodeURIComponent('আমি ব্লগ ওয়েবসাইট তৈরি করার বিষয়ে বিস্তারিত জানতে চাই।')">
                      <div style="display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: linear-gradient(135deg, #22c55e, #16a34a); border-radius: 50%; color: #fff; box-shadow: 0 4px 10px rgba(34, 197, 94, 0.2);"><i class="bi bi-check-lg" style="font-size: 0.9rem; stroke-width: 1px;"></i></div> ব্লগ ওয়েবসাইট
                    </li>
                    <li style="display: flex; align-items: center; gap: 12px; font-weight: 600; color: #334155; font-size: 0.95rem; cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='#334155'" data-bs-toggle="modal" data-bs-target="#webDevModal" onclick="document.getElementById('webDevModalLink').href='<%= waUrlBase %><%= waUrlBase.includes('?') ? '&' : '?' %>text='+encodeURIComponent('আমি অনলাইন সার্ভিস সংক্রান্ত ওয়েবসাইট তৈরি করার বিষয়ে বিস্তারিত জানতে চাই।')">
                      <div style="display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: linear-gradient(135deg, #22c55e, #16a34a); border-radius: 50%; color: #fff; box-shadow: 0 4px 10px rgba(34, 197, 94, 0.2);"><i class="bi bi-check-lg" style="font-size: 0.9rem; stroke-width: 1px;"></i></div> অনলাইন সার্ভিস সংক্রান্ত ওয়েবসাইট
                    </li>
                    <li style="display: flex; align-items: center; gap: 12px; font-weight: 600; color: #334155; font-size: 0.95rem; cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='#334155'" data-bs-toggle="modal" data-bs-target="#webDevModal" onclick="document.getElementById('webDevModalLink').href='<%= waUrlBase %><%= waUrlBase.includes('?') ? '&' : '?' %>text='+encodeURIComponent('আমি ক্লায়েন্টের চাহিদা অনুযায়ী ওয়েবসাইট তৈরি করার বিষয়ে বিস্তারিত জানতে চাই।')">
                      <div style="display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: linear-gradient(135deg, #22c55e, #16a34a); border-radius: 50%; color: #fff; box-shadow: 0 4px 10px rgba(34, 197, 94, 0.2);"><i class="bi bi-check-lg" style="font-size: 0.9rem; stroke-width: 1px;"></i></div> ক্লায়েন্টের চাহিদা অনুযায়ী ওয়েবসাইট
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
          <div style="padding: 0 30px 35px; text-align: center; position: relative; z-index: 1;">
            <a href="<%= waUrlBase %>" target="_blank" style="display: inline-flex; align-items: center; justify-content: center; gap: 10px; text-decoration: none; background: linear-gradient(135deg, #25D366, #128C7E); color: #fff; padding: 15px 40px; border-radius: 50px; font-weight: 700; font-size: 1.05rem; box-shadow: 0 10px 25px rgba(37, 211, 102, 0.35); transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);" onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 15px 30px rgba(37, 211, 102, 0.45)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 25px rgba(37, 211, 102, 0.35)';">
              <i class="bi bi-whatsapp" style="font-size: 1.3rem;"></i> বিস্তারিত জানতে যোগাযোগ করুন
            </a>
          </div>
        </div>
        <!-- Web Dev WhatsApp Modal -->
        <div class="modal fade" id="webDevModal" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border: none; border-radius: 16px; overflow: hidden; box-shadow: 0 15px 35px rgba(0,0,0,0.2);">
              <div class="modal-body p-5 text-center position-relative">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" style="position: absolute; top: 15px; right: 15px; z-index: 10;"></button>
                <div style="width: 70px; height: 70px; background: rgba(37, 211, 102, 0.1); color: #25d366; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-size: 2rem;">
                  <i class="bi bi-headset"></i>
                </div>
                <h4 style="font-weight: 700; color: #1e293b; margin-bottom: 12px; font-size: 1.2rem;">বিস্তারিত জানতে যোগাযোগ করুন</h4>
                <p style="color: #64748b; margin-bottom: 25px; font-size: 0.95rem;">এই সার্ভিসটি সম্পর্কে বিস্তারিত তথ্য জানতে এবং অর্ডার করতে সরাসরি আমাদের WhatsApp-এ মেসেজ দিন।</p>
                <a href="<%= waUrlBase %>" id="webDevModalLink" target="_blank" class="btn w-100" style="background: linear-gradient(135deg, #25D366, #128C7E); color: #fff; padding: 12px; border-radius: 50px; font-weight: 600; font-size: 1.05rem; box-shadow: 0 5px 15px rgba(37, 211, 102, 0.2);">
                  <i class="bi bi-whatsapp me-2"></i> WhatsApp-এ মেসেজ দিন
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- Directors Column (Right side on PC, Bottom on Mobile) -->
      <div class="col-lg-3">
        <% if (directors && directors.length > 0) { %>
          <div class="director-sidebar" style="position: sticky; top: 90px;">
            <% directors.forEach((d, idx) => { %>
              <div class="director-card reveal" style="background:#fff;border-radius:12px;box-shadow:0 10px 30px rgba(0,0,0,0.05);overflow:hidden;margin-bottom:20px;border:1px solid #e2e8f0; <%= idx > 0 ? 'margin-top: 24px;' : '' %>">
                <div class="director-img-wrap" style="height:250px;width:100%;background:#f1f5f9;position:relative;border-bottom:3px solid var(--primary-color)">
                  <img src="<%= d.imageUrl || '/images/teacher-default.jpg' %>" alt="<%= d.name %>" style="width:100%;height:100%;object-fit:contain;object-position:center;padding:10px;">
                </div>
                <div class="p-4 text-center">
                  <h4 style="font-weight:700;color:#1e293b;font-size:1.15rem;margin-bottom:6px;"><%= d.name %></h4>
                  <p style="color:var(--primary-color);font-weight:600;font-size:.9rem;margin-bottom:6px;"><%= d.designation %></p>
                  <% if(d.institution) { %>
                    <p style="color:#64748b;font-size:.85rem;margin-bottom:15px;line-height:1.4;"><%= d.institution %></p>
                  <% } %>
                  <button type="button" class="btn btn-outline-primary btn-sm w-100" data-bs-toggle="modal" data-bs-target="#directorModal<%= d.id %>" style="border-radius:6px;font-weight:600;">
                    বিস্তারিত দেখুন
                  </button>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
<!-- ── RESULT CTA ───────────────────────────────────── -->
<section class="section section-alt">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-7 reveal">
        <div class="section-title">ফলাফল দেখুন মুহূর্তেই</div>
        <div class="section-line"></div>
        <p class="section-subtitle mb-4">আপনার রেজিস্ট্রেশন নম্বর দিয়ে সরাসরি আপনার পরীক্ষার ফলাফল দেখুন। কোনো ঝামেলা নেই — সহজেই অনলাইনে।</p>
        <a href="/result" class="btn-primary-custom"><i class="bi bi-search"></i> এখনই ফলাফল দেখুন</a>
        <a href="/admission" class="btn-gold ms-3 mt-2"><i class="bi bi-pen"></i> অনলাইনে ভর্তি হন</a>
      </div>
      <div class="col-lg-5 text-center mt-4 mt-lg-0 reveal">
        <form action="/result" method="GET" style="background:linear-gradient(135deg,#0A1628,#112240);border-radius:20px;padding:40px;border:2px solid rgba(30,144,255,.2);">
          <div style="font-size:3rem;margin-bottom:16px;">📋</div>
          <div style="color:#fff;font-size:1.1rem;font-weight:700;margin-bottom:15px;">রেজিস্ট্রেশন নম্বর লিখুন</div>
          <input type="text" name="regNo" class="form-control mb-3" placeholder="যেমন: AB54X2" required autocomplete="off" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.2);color:#fff;text-align:center;padding:12px;border-radius:10px;">
          <button type="submit" class="btn-primary-custom w-100" style="border:none;padding:12px;border-radius:10px;font-weight:600;"><i class="bi bi-search me-2"></i>ফলাফল দেখুন</button>
        </form>
      </div>
    </div>
  </div>
</section>
<!-- ── COUNTERS ─────────────────────────────────────── -->
<section class="counters-section">
  <div class="container">
    <div class="row g-3">
      <div class="col-6 col-md-3">
        <div class="counter-card">
          <div class="counter-icon">🎓</div>
          <div class="counter-number" data-target="<%= counters.students || 0 %>">০</div>
          <div class="counter-label">সফল শিক্ষার্থী</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <a href="/courses" style="text-decoration: none; color: inherit; display: block;">
          <div class="counter-card" style="cursor: pointer; transition: transform 0.3s ease; box-shadow: 0 4px 15px rgba(0,0,0,0.05);" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
            <div class="counter-icon">📚</div>
            <div class="counter-number" data-target="<%= counters.courses || 0 %>">০</div>
            <div class="counter-label">কোর্স সমূহ</div>
          </div>
        </a>
      </div>
      <div class="col-6 col-md-3">
        <div class="counter-card">
          <div class="counter-icon">👨‍🏫</div>
          <div class="counter-number" data-target="<%= counters.teachers || 15 %>">০</div>
          <div class="counter-label">দক্ষ শিক্ষক</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="counter-card">
          <div class="counter-icon">🏆</div>
          <div class="counter-number" data-target="<%= counters.years || 10 %>">০</div>
          <div class="counter-label">বছরের অভিজ্ঞতা</div>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- ── NOTICES ──────────────────────────────────────── -->
<% if (notices && notices.length > 0) { %>
<section class="section">
  <div class="container">
    <div class="row">
      <div class="col-lg-8">
        <div class="section-title reveal">সাম্প্রতিক নোটিশ</div>
        <div class="section-line reveal"></div>
        <% notices.slice(0,4).forEach(n => { %>
        <div class="notice-card reveal">
          <div class="notice-date-box">
            <div class="day"><%= new Date(n.date).getDate() || '—' %></div>
            <div class="month"><%= n.date ? new Date(n.date).toLocaleString('bn-BD',{month:'short'}) : '' %></div>
          </div>
          <div>
            <div class="notice-title"><%= n.title %></div>
            <div class="notice-body"><%= (n.body || '').substring(0,120) %></div>
          </div>
        </div>
        <% }); %>
        <a href="/notices" class="btn-outline-gold mt-3">সব নোটিশ দেখুন <i class="bi bi-arrow-right"></i></a>
      </div>
      <!-- Teachers sidebar -->
      <div class="col-lg-4 mt-4 mt-lg-0">
        <div class="section-title reveal">আমাদের শিক্ষকবৃন্দ</div>
        <div class="section-line reveal"></div>
        <div class="row g-3 mt-1">
          <% teachers.slice(0,4).forEach(t => { %>
          <div class="col-6 reveal">
            <div class="teacher-card">
              <div class="teacher-img-wrap" style="height:140px">
                <img src="<%= t.imageUrl || '/images/teacher-default.jpg' %>" alt="<%= t.name %>" onerror="this.onerror=null;this.src='/images/teacher-default.jpg'" />
              </div>
              <div class="teacher-info" style="padding:12px">
                <div class="teacher-name" style="font-size:.85rem"><%= t.name %></div>
                <div class="teacher-desig" style="font-size:.75rem"><%= t.designation %></div>
              </div>
            </div>
          </div>
          <% }); %>
        </div>
        <a href="/teachers" class="btn-outline-gold mt-3 d-block text-center">সব শিক্ষক দেখুন</a>
      </div>
    </div>
  </div>
</section>
<% } %>
<!-- ── BLOG POSTS ────────────────────────────────────── -->
<% if (posts && posts.length > 0) { %>
<section class="section section-alt">
  <div class="container">
    <div class="text-center mb-5 reveal">
      <div class="section-title">আইটি তথ্য ও ব্লগ</div>
      <div class="section-line mx-auto"></div>
    </div>
    <div class="row g-4">
      <% posts.forEach(p => { %>
      <div class="col-md-4 reveal">
        <div class="course-card">
          <div class="course-card-img">
            <img src="<%= p.imageUrl || '/images/blog-default.jpg' %>" alt="<%= p.title %>" />
          </div>
          <div class="course-card-body">
            <div class="course-meta"><span><i class="bi bi-calendar3"></i> <%= p.date || '' %></span></div>
            <h3 class="course-card-title"><%= p.title %></h3>
            <p class="course-card-desc"><%= (p.content || '').replace(/<[^>]*>/g,'').substring(0,100) %>...</p>
            <a href="/blog/<%= p.id %>" class="btn-course">পড়ুন <i class="bi bi-arrow-right"></i></a>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>
<% } %>
<!-- ── CONTACT STRIP ─────────────────────────────────── -->
<section class="section" style="background:linear-gradient(135deg,#0A1628,#112240)">
  <div class="container text-center">
    <div class="section-title text-white reveal">আমাদের সাথে যোগাযোগ করুন</div>
    <div class="section-line mx-auto reveal"></div>
    <p class="text-white-50 mb-4 reveal">যেকোনো প্রশ্ন বা তথ্যের জন্য আমাদের সাথে যোগাযোগ করুন</p>
    <div class="d-flex justify-content-center gap-3 flex-wrap reveal">
      <a href="tel:<%= site.phone %>" class="btn-hero-primary"><i class="bi bi-telephone"></i> <%= site.phone || 'কল করুন' %></a>
      <a href="<%= typeof waUrlBase !== 'undefined' ? waUrlBase : 'https://wa.me/' + (site.whatsappNumber || '').replace(/[^\d+]/g, '') %>" target="_blank" class="btn" style="background: linear-gradient(135deg, #25D366, #128C7E); color: #fff; padding: 12px 30px; border-radius: 50px; font-weight: 600; font-size: 1.05rem; box-shadow: 0 8px 20px rgba(37, 211, 102, 0.25); transition: all 0.3s ease;" onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 12px 25px rgba(37, 211, 102, 0.35)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 8px 20px rgba(37, 211, 102, 0.25)';"><i class="bi bi-whatsapp"></i> WhatsApp</a>
      <a href="/contact" class="btn-hero-secondary"><i class="bi bi-envelope"></i> বার্তা পাঠান</a>
    </div>
  </div>
</section>
</main>
<!-- ── DIRECTOR MODALS (Placed outside sticky containers) ── -->
<% if (typeof directors !== 'undefined' && directors && directors.length > 0) { %>
  <% directors.forEach((d) => { %>
    <div class="modal fade" id="directorModal<%= d.id %>" tabindex="-1">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border:none;border-radius:12px;overflow:hidden;">
          <div class="modal-header" style="background:var(--primary-color);color:#fff;border:none;">
            <h5 class="modal-title" style="font-weight:600;"><i class="bi bi-person-badge me-2"></i>পরিচালকের বিস্তারিত তথ্য</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body p-4 text-center">
            <img src="<%= d.imageUrl || '/images/teacher-default.jpg' %>" style="max-width: 250px; width: 100%; height: auto; border-radius: 8px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); margin-bottom: 15px;">
            <h4 style="font-weight:700;color:#1e293b;margin-bottom:5px;"><%= d.name %></h4>
            <p style="color:var(--primary-color);font-weight:600;margin-bottom:5px;"><%= d.designation %></p>
            <% if(d.institution) { %><p style="color:#64748b;font-size:.9rem;margin-bottom:5px;"><i class="bi bi-building me-1"></i><%= d.institution %></p><% } %>
            <% if(d.address) { %><p style="color:#64748b;font-size:.9rem;margin-bottom:15px;"><i class="bi bi-geo-alt me-1"></i><%= d.address %></p><% } %>
            <% if(d.message) { %>
              <div style="background:#f8fafc;padding:15px;border-radius:8px;text-align:left;font-size:.95rem;color:#475569;border-left:4px solid var(--primary-color);white-space:pre-wrap;"><%= d.message %></div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  <% }); %>
<% } %>
<%- include('../partials/footer') %>
<div class="lightbox" id="lightbox"><button class="lightbox-close" id="lightboxClose">&times;</button><img src="" id="lightboxImg" alt="" /></div>
<div class="alert-placeholder" style="position:fixed;top:20px;left:50%;transform:translateX(-50%);z-index:9999;width:90%;max-width:500px;"></div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
